{
  "env": {
    "MCP_OUTPUT_DIR": ".claude/mcp-output"
  },
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(git:*)",
      "Bash(netstat:*)",
      "Bash(tasklist:*)",
      "Bash(taskkill:*)",
      "Bash(curl:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsx:*)",
      "Bash(npm test:*)",
      "Bash(npx vitest:*)",
      "mcp__ide__executeCode",
      "Bash(npx tsc:*)",
      "Bash(find .:*)",
      "Bash(npx eslint:*)",
      "Bash(npx chrome-devtools-mcp@latest:*)",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__new_page",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__get_console_message",
      "mcp__chrome-devtools__list_network_requests",
      "Read(//c/Users/$USER/AppData/**)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(npx next:*)",
      "Read(//c/Users/Xing/.claude/plugins/cache/superpowers-marketplace/superpowers/4.3.1/skills/**)",
      "Read(//c/Users/Xing/.claude/**)",
      "mcp__chrome-devtools__press_key",
      "Bash(npx ts-node:*)"
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "行到水穷处-ing",
      "坐看云起时-ing",
      "采菊东篱下-ing",
      "悠然见南山-ing",
      "人闲桂花落-ing",
      "夜静春山空-ing",
      "蝉噪林逾静-ing",
      "鸟鸣山更幽-ing",
